#!/bin/sh

# Run on pre-push: fmt, clippy, and test

set -e

echo "🚀 Running pre-push checks..."

echo "📚 Verifying docs sync state..."
cargo run --quiet --bin docs-sync -- guard
cargo run --quiet --bin docs-sync -- check

echo "📝 Formatting code..."
cargo fmt --all -- --check

echo "🔍 Running clippy..."
cargo clippy --all-targets --all-features -- -D warnings

echo "🧪 Running tests..."
cargo test

echo "✅ Pre-push checks passed!"
